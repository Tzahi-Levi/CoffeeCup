# Turso database URL (e.g. libsql://your-db.turso.io)
# Leave blank to use a local SQLite file (file:./local.db)
TURSO_DATABASE_URL="libsql://your-db-name.turso.io"

# Turso auth token — get from: turso db tokens create your-db
TURSO_AUTH_TOKEN="your-turso-auth-token"

# Supabase project URL — get from: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase JWT secret — only needed for HS256 projects (legacy)
# For RS256 projects (default for new projects) the JWKS public key is fetched automatically via SUPABASE_URL
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# Server port (default: 3000)
PORT=3000
